---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
  eyebrow?: string;
  title: string;
  body: string;
  image: ImageMetadata;
  alt: string;
  compact?: boolean;
};

const { eyebrow, title, body, image, alt, compact = false } = Astro.props;
---

<section class:list={["hero", compact && "hero--compact"]} aria-label={eyebrow ?? title}>
  <Image
    class="hero__image"
    src={image}
    alt={alt}
    widths={[320, 480, 640, 960, 1280, 1600]}
    sizes="(max-width: 760px) 25vw, 100vw"
    quality={35}
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="hero__content">
    <div class="hero__content-inner">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="hero__title">{title}</h1>
      <p class="hero__subhead">{body}</p>
    </div>
  </div>
</section>
