---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type GalleryItem = {
  image: ImageMetadata;
  alt: string;
};

type Props = {
  gallery: GalleryItem[];
};

const { gallery } = Astro.props;
---

{
  gallery.length > 0 && (
    <section class="section" aria-label="Photo gallery">
      <div class="wrapper feature-grid">
        {gallery.map((item) => (
          <Image
            class="destination-card-image"
            src={item.image}
            alt={item.alt}
            widths={[400, 560, 768, 960, 1200]}
            sizes="(max-width: 760px) 100vw, 33vw"
            quality={62}
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
    </section>
  )
}
