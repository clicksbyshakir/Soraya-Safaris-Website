---
import AboutSections from "../components/AboutSections.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import heroImage from "../assets/pleiades.jpg";
import { pageTitle } from "../lib/site";

const description =
  "Soraya Safaris is named for the Pleiades, the star cluster that guided travelers home. Meet the founders in Nairobi, Boston, and Ottawa.";
---

<BaseLayout
  title={pageTitle("Our Story")}
  description={description}
  canonicalPath="/our-story"
  current="about"
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Our Story", path: "/our-story" }
  ]}
>
    <Hero
      compact
      eyebrow="Our story"
      title="The stars that brought travelers home."
      body="Across the Swahili coast and the Arab world, the Pleiades are known as Soraya. We took our name from them."
      image={heroImage}
      alt="The Pleiades star cluster, a bright group of blue stars wrapped in nebulosity against a black sky."
    />
    <AboutSections />
    <FinalCTA
      eyebrow="Find your way through Kenya"
      title="Let us help you find your way through Kenya."
      body="Tell us what you are imagining, even if the idea is still early. We will help make the choices clear."
    />
</BaseLayout>
