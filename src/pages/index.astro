---
import { Image } from "astro:assets";

import FinalCTA from "../components/FinalCTA.astro";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { destinationHeroImage, destinationPath, getSortedDestinations } from "../lib/destinations";
import heroImage from "../assets/hero-leopard.jpg";
import storyImage from "../assets/giraffe-pair.jpg";
import { organizationJsonLd, pageTitle } from "../lib/site";

const description = "Private Kenya safaris, thoughtfully planned by people who call Kenya home.";

const featuredDestinations = (await getSortedDestinations()).slice(0, 3);

const whyUs = [
  {
    title: "Born-and-raised local knowledge",
    body:
      "Our planning starts from a lived connection to Kenya, not a reseller's list of parks and lodges."
  },
  {
    title: "Curated for you, never off the shelf",
    body:
      "The route is shaped around your dates, your group, your pace, and the things you actually care about seeing. Nothing is lifted from a fixed package."
  },
  {
    title: "An on-the-ground team in Nairobi",
    body:
      "Planning is supported by local presence, current context, and people close to the journey as it unfolds."
  },
  {
    title: "Nairobi, Boston, and Ottawa",
    body:
      "With offices on both sides of the ocean, your questions get answered in your own time zone, long before you fly."
  }
];

const processSteps = [
  {
    title: "Send one message",
    body: "Your dates, who is coming, and what you hope Kenya will feel like. That is all we need to start."
  },
  {
    title: "We do the work",
    body: "Seasons, routes, drive times, camps, and permits. We research it all and come back to you with a plan."
  },
  {
    title: "You get a clear quote",
    body: "One itinerary, one honest price. Change anything you like, as many times as you like."
  },
  {
    title: "Confirm and pay securely",
    body: "Once you approve the quote, we send a secure payment link. Pay by major credit or debit card through the same kind of checkout you already use at home, and you receive a formal invoice for your records."
  },
  {
    title: "You just show up",
    body: "Transfers, guides, lodges, and logistics are handled. Your only job is to look out of the window."
  }
];
---

<BaseLayout
  title={pageTitle("Home")}
  description={description}
  canonicalPath="/"
  current="home"
  jsonLd={organizationJsonLd()}
>
    <Hero
      title="Let the stars guide you to the savannah."
      body="Private Kenya safaris, thoughtfully planned by people who call Kenya home."
      note="Built for first-time travellers from Canada and the US. Most safaris hand you a fixed itinerary. We start with your dates and the things you actually want to see, plan the trip around them from comfortable to high-end, and let you pay securely by card."
      image={heroImage}
      alt="Leopard resting in a tree in Kenya, used as a warm safari hero image."
    />

    <section class="trust-strip" aria-label="What travelers can expect">
      <ul class="wrapper trust-items">
        <li>Kenya-focused</li>
        <li>Locally grounded</li>
        <li>Curated for every traveler</li>
        <li>Supported start to finish</li>
      </ul>
    </section>

    <section class="section story-band">
      <div class="wrapper split-layout">
        <div>
          <p class="eyebrow">Guided by home</p>
          <h2>No two safaris are ever the same.</h2>
          <p>
            We start with a conversation, not a catalogue. Your dates, your pace, the people
            you are travelling with, and the things you actually want to see are what shape
            the route from the very first draft.
          </p>
          <p>
            Then we handle the rest. Routes, camps, permits, drivers, timings, and the small
            details you would never think to ask about are all taken care of, so the only
            thing left for you to do is show up and look out of the window.
          </p>
        </div>
      <Image
        src={storyImage}
        alt="Two giraffes standing in green Kenya bush, used as a placeholder destination image."
        widths={[480, 640, 768, 960, 1280, 1600]}
        sizes="(max-width: 760px) 100vw, 50vw"
        quality={62}
        loading="lazy"
        decoding="async"
      />
      </div>
    </section>

    <section class="section">
      <div class="wrapper section-head">
        <p class="eyebrow">Why us</p>
        <h2>You dream it. We take care of everything else.</h2>
      </div>
      <div class="wrapper value-grid">
        {
          whyUs.map((item) => (
            <article class="value-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section split-feature">
      <div class="wrapper section-head">
        <p class="eyebrow">Featured destinations</p>
        <h2>Tell us where you have always wanted to wake up.</h2>
      </div>
      <div class="wrapper feature-grid">
        {
          featuredDestinations.map((destination) => (
          <a class="photo-card linked-card" href={destinationPath(destination)}>
            <Image
              src={destinationHeroImage(destination)}
              alt={destination.data.heroImageAlt}
              widths={[400, 560, 768, 960, 1200]}
              sizes="(max-width: 760px) 100vw, 33vw"
              quality={62}
              loading="lazy"
              decoding="async"
            />
              <div>
                <p class="card-kicker">{destination.data.region}</p>
                <h3>{destination.data.name}</h3>
                <span class="text-link">Explore destinations</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="wrapper section-head">
        <p class="eyebrow">How it works</p>
        <h2>From your first message to your first sunrise.</h2>
      </div>
      <ol class="wrapper flow">
        {
          processSteps.map((step, index) => (
            <li class="flow__step">
              <span class="flow__marker" aria-hidden="true">{index + 1}</span>
              <div class="flow__body">
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <FinalCTA
      eyebrow="Begin with a conversation"
      title="Your dream safari is a conversation away."
      body="Tell us what you are imagining, even if the idea is still rough. We will take it from there."
      cta="Get a free quote today"
    />
</BaseLayout>
