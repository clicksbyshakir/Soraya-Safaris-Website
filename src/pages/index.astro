---
import { Image } from "astro:assets";

import FinalCTA from "../components/FinalCTA.astro";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { destinations } from "../data/destinations";
import heroImage from "../assets/hero-leopard.jpg";
import storyImage from "../assets/giraffe-pair.jpg";
import { organizationJsonLd, pageTitle } from "../lib/site";

const description = "Private Kenya safaris, thoughtfully planned by people who call Kenya home.";

const whyUs = [
  {
    title: "Born-and-raised local knowledge",
    body:
      "Our planning starts from a lived connection to Kenya, not a reseller's list of parks and lodges."
  },
  {
    title: "Curated for you, never off the shelf",
    body:
      "The route is shaped around your dates, your group, your pace, and the things you actually care about seeing. Nothing is lifted from a fixed package."
  },
  {
    title: "An on-the-ground team in Nairobi",
    body:
      "Planning is supported by local presence, current context, and people close to the journey as it unfolds."
  },
  {
    title: "Nairobi, Boston, and Ottawa",
    body:
      "With offices on both sides of the ocean, your questions get answered in your own time zone, long before you fly."
  }
];

const processSteps = [
  {
    title: "Tell us your plans",
    body: "Share your dates, who is travelling, and what you hope Kenya will feel like."
  },
  {
    title: "We design the route together",
    body: "We talk through options, seasons, drive times, and camps in plain language, then draft your itinerary."
  },
  {
    title: "You get a clear quote",
    body: "One tailored itinerary, one transparent price. Refine it with us as many times as you need."
  },
  {
    title: "Confirm and pay securely",
    body: "When the itinerary is right, you confirm it and pay through a secure payment link."
  },
  {
    title: "Your safari begins",
    body: "You travel with our Kenya team on the ground and a real person to call throughout the journey."
  }
];
---

<BaseLayout
  title={pageTitle("Home")}
  description={description}
  canonicalPath="/"
  current="home"
  jsonLd={organizationJsonLd()}
>
    <Hero
      title="Let the stars guide you to the savannah."
      body="Private Kenya safaris, thoughtfully planned by people who call Kenya home."
      image={heroImage}
      alt="Leopard resting in a tree in Kenya, used as a warm safari hero image."
    />

    <section class="trust-strip" aria-label="What travelers can expect">
      <ul class="wrapper trust-items">
        <li>Kenya-focused</li>
        <li>Locally grounded</li>
        <li>Curated for every traveler</li>
        <li>Supported start to finish</li>
      </ul>
    </section>

    <section class="section story-band">
      <div class="wrapper split-layout">
        <div>
          <p class="eyebrow">Guided by home</p>
          <h2>No two safaris we plan are ever the same.</h2>
          <p>
            We start with a conversation, not a catalogue. Your dates, your pace, the people
            you are travelling with, and the things you actually want to see are what shape
            the route from the very first draft.
          </p>
          <p>
            From there we build the journey around you, and keep refining it until it reads
            like your trip rather than a package someone else booked.
          </p>
        </div>
      <Image
        src={storyImage}
        alt="Two giraffes standing in green Kenya bush, used as a placeholder destination image."
        widths={[240, 320, 480]}
        sizes="(max-width: 760px) 25vw, 50vw"
        quality={40}
        loading="lazy"
        decoding="async"
      />
      </div>
    </section>

    <section class="section">
      <div class="wrapper section-head">
        <p class="eyebrow">Why us</p>
        <h2>Planning rooted in Kenya, shaped entirely around you.</h2>
      </div>
      <div class="wrapper value-grid">
        {
          whyUs.map((item) => (
            <article class="value-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section split-feature">
      <div class="wrapper section-head">
        <p class="eyebrow">Featured destinations</p>
        <h2>Start with the landscape, then we will shape the route.</h2>
      </div>
      <div class="wrapper feature-grid">
        {
          destinations.slice(0, 3).map((destination) => (
          <a class="photo-card linked-card" href={`/destinations#${destination.slug}`}>
            <Image
              src={destination.image}
              alt={destination.imageAlt}
              widths={[240, 320, 480]}
              sizes="(max-width: 760px) 25vw, 33vw"
              quality={40}
              loading="lazy"
              decoding="async"
            />
              <div>
                <p class="card-kicker">{destination.region}</p>
                <h3>{destination.name}</h3>
                <span class="text-link">Explore destinations</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="wrapper section-head">
        <p class="eyebrow">How it works</p>
        <h2>From your first message to your first sunrise.</h2>
      </div>
      <ol class="wrapper flow">
        {
          processSteps.map((step, index) => (
            <li class="flow__step">
              <span class="flow__marker" aria-hidden="true">{index + 1}</span>
              <div class="flow__body">
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <FinalCTA
      eyebrow="Begin with a conversation"
      title="Your Kenya journey begins with a conversation."
      body="Share your dates, interests, and the kind of experience you imagine. We will help turn the first idea into a journey that feels entirely your own."
    />
</BaseLayout>
