---
import { render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import {
  formatPostDate,
  getPublishedPosts,
  postDate,
  postHeroImage,
  postPath,
  postSlug,
  tagPath
} from "../../lib/blog";
import {
  absoluteUrl,
  DEFAULT_OG_ALT,
  pageTitle,
  SITE_NAME
} from "../../lib/site";
import type { BlogPost } from "../../lib/blog";

type Props = {
  post: BlogPost;
};

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: postSlug(post.id) },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const tags = post.data.tags ?? [];
const heroImage = postHeroImage(post);
const heroAlt = heroImage === post.data.heroImage ? post.data.title : DEFAULT_OG_ALT;
const description = post.data.description;
const publishedDate = postDate(post);
const canonicalPath = postPath(post);
const publishedTime = publishedDate.toISOString();
const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description,
  datePublished: publishedTime,
  dateModified: publishedTime,
  image: absoluteUrl(heroImage),
  mainEntityOfPage: absoluteUrl(canonicalPath),
  author: {
    "@type": "Organization",
    name: SITE_NAME,
    url: absoluteUrl("/")
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME,
    logo: {
      "@type": "ImageObject",
      url: absoluteUrl("/icon-512.png")
    }
  }
};
---

<BlogLayout
  title={pageTitle(post.data.title)}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={heroImage}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={publishedTime}
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
    { name: post.data.title, path: canonicalPath }
  ]}
  jsonLd={blogPostingJsonLd}
>
  <article class="blog-post">
    <header class="blog-post__header">
      <div class="container container--narrow blog-post__intro">
        <a class="blog-post__back" href="/blog">Back to blog</a>
        <p class="blog-post__date">{formatPostDate(publishedDate)}</p>
        <h1>{post.data.title}</h1>
        {description && <p class="blog-post__description">{description}</p>}
        {tags.length > 0 && (
          <ul class="blog-post__tags" aria-label="Tags">
            {tags.map((tag) => (
              <li>
                <a href={tagPath(tag)}>{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </div>
      <div class="container blog-post__media">
        <img
          src={heroImage}
          alt={heroAlt}
          width="1600"
          height="960"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </header>

    <div class="container container--narrow blog-prose">
      <Content />
    </div>

    <section class="container container--narrow blog-cta" aria-labelledby="blog-cta-title">
      <p class="blog-cta__eyebrow">Begin with a conversation</p>
      <h2 id="blog-cta-title">Ready to see it in person?</h2>
      <p>Let's plan your safari with dates, pacing, and places shaped around you.</p>
      <a href="/contact">Plan your safari</a>
    </section>
  </article>
</BlogLayout>

<style>
  .blog-post {
    padding-block: var(--space-10) var(--space-20);
  }

  .blog-post__header {
    display: grid;
    gap: var(--space-8);
  }

  .blog-post__intro {
    display: grid;
    gap: var(--space-4);
  }

  .blog-post__back {
    width: fit-content;
    color: var(--color-clay);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }

  .blog-post__back:hover {
    color: var(--color-midnight);
  }

  .blog-post__date {
    margin: 0;
    color: var(--color-clay);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
  }

  .blog-post__intro h1 {
    margin: 0;
    color: var(--color-midnight);
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: var(--weight-semibold);
    line-height: var(--line-heading);
    overflow-wrap: anywhere;
  }

  .blog-post__description {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: var(--text-md);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .blog-post__tags a {
    min-height: 2.25rem;
    display: inline-flex;
    align-items: center;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface-raised);
    padding-inline: var(--space-3);
    color: var(--color-acacia);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
  }

  .blog-post__tags a:hover {
    border-color: var(--color-gold);
    color: var(--color-midnight);
  }

  .blog-post__media img {
    width: 100%;
    max-height: 38rem;
    border-radius: var(--radius-md);
    object-fit: cover;
    background: var(--color-surface-warm);
  }

  .blog-prose {
    padding-block-start: var(--space-10);
    color: var(--color-ink);
    font-size: var(--text-md);
    line-height: 1.72;
  }

  .blog-prose :global(*) {
    overflow-wrap: break-word;
  }

  .blog-prose :global(:first-child) {
    margin-block-start: 0;
  }

  .blog-prose :global(:last-child) {
    margin-block-end: 0;
  }

  .blog-prose :global(h2),
  .blog-prose :global(h3),
  .blog-prose :global(h4) {
    margin-block: var(--space-10) var(--space-4);
    color: var(--color-midnight);
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    line-height: var(--line-heading);
  }

  .blog-prose :global(h2) {
    font-size: var(--text-3xl);
  }

  .blog-prose :global(h3) {
    font-size: var(--text-2xl);
  }

  .blog-prose :global(h4) {
    font-size: var(--text-xl);
  }

  .blog-prose :global(p),
  .blog-prose :global(ul),
  .blog-prose :global(ol),
  .blog-prose :global(blockquote),
  .blog-prose :global(table),
  .blog-prose :global(pre),
  .blog-prose :global(figure) {
    margin-block: 0 var(--space-6);
  }

  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    padding-inline-start: var(--space-6);
  }

  .blog-prose :global(li + li) {
    margin-block-start: var(--space-2);
  }

  .blog-prose :global(li > ul),
  .blog-prose :global(li > ol) {
    margin-block: var(--space-2) 0;
  }

  .blog-prose :global(a) {
    color: var(--color-clay);
    font-weight: var(--weight-semibold);
  }

  .blog-prose :global(a:hover) {
    color: var(--color-midnight);
  }

  .blog-prose :global(blockquote) {
    border-inline-start: 0.25rem solid var(--color-gold);
    background: color-mix(in srgb, var(--color-sand) 38%, transparent);
    padding: var(--space-5);
    color: var(--color-midnight);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.35;
  }

  .blog-prose :global(blockquote p) {
    margin: 0;
  }

  .blog-prose :global(img) {
    width: 100%;
    border-radius: var(--radius-md);
    background: var(--color-surface-warm);
  }

  .blog-prose :global(figure) {
    display: grid;
    gap: var(--space-2);
  }

  .blog-prose :global(figcaption) {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }

  .blog-prose :global(code) {
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--color-midnight) 8%, transparent);
    padding: 0.1em 0.35em;
    color: var(--color-midnight);
    font-size: 0.9em;
  }

  .blog-prose :global(pre) {
    overflow-x: auto;
    border-radius: var(--radius-md);
    background: var(--color-midnight);
    padding: var(--space-5);
    color: var(--color-ivory);
  }

  .blog-prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .blog-prose :global(table) {
    width: 100%;
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .blog-prose :global(th),
  .blog-prose :global(td) {
    border: var(--border-width) solid var(--color-border);
    padding: var(--space-3);
    text-align: start;
    vertical-align: top;
  }

  .blog-prose :global(th) {
    background: color-mix(in srgb, var(--color-sand) 44%, transparent);
    color: var(--color-midnight);
    font-weight: var(--weight-bold);
  }

  .blog-cta {
    display: grid;
    gap: var(--space-4);
    margin-block-start: var(--space-12);
    border: var(--border-width) solid color-mix(in srgb, var(--color-gold) 48%, var(--color-border));
    border-radius: var(--radius-md);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-sand) 60%, transparent), transparent),
      var(--color-surface-raised);
    padding: var(--space-8);
  }

  .blog-cta__eyebrow,
  .blog-cta p,
  .blog-cta h2 {
    margin: 0;
  }

  .blog-cta__eyebrow {
    color: var(--color-clay);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
  }

  .blog-cta h2 {
    color: var(--color-midnight);
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-semibold);
    line-height: var(--line-heading);
  }

  .blog-cta p {
    color: var(--color-ink-muted);
    font-size: var(--text-md);
  }

  .blog-cta a {
    width: fit-content;
    min-height: var(--tap-target);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    background: var(--color-midnight);
    padding: var(--space-3) var(--space-5);
    color: var(--color-ivory);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }

  .blog-cta a:hover {
    background: var(--color-acacia);
  }
</style>
