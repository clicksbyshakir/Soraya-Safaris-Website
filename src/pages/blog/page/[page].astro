---
import BlogCard from "../../../components/BlogCard.astro";
import BlogLayout from "../../../layouts/BlogLayout.astro";
import {
  blogPagePath,
  getPagePosts,
  getPublishedPosts,
  getTotalPages,
  POSTS_PER_PAGE
} from "../../../lib/blog";
import { DEFAULT_OG_IMAGE, pageTitle } from "../../../lib/site";
import type { BlogPost } from "../../../lib/blog";

type Props = {
  pageNumber: number;
  pagePosts: BlogPost[];
  totalPages: number;
  totalPosts: number;
};

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const totalPages = getTotalPages(posts);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const pageNumber = index + 2;
    return {
      params: { page: String(pageNumber) },
      props: {
        pageNumber,
        pagePosts: getPagePosts(posts, pageNumber),
        totalPages,
        totalPosts: posts.length
      }
    };
  });
}

const { pageNumber, pagePosts, totalPages, totalPosts } = Astro.props;
const previousPage = pageNumber - 1;
const nextPage = pageNumber + 1;
---

<BlogLayout
  title={pageTitle(`Blog Page ${pageNumber}`)}
  description="More Kenya safari planning stories, seasonal guidance, and field-informed ideas."
  canonicalPath={blogPagePath(pageNumber)}
  ogImage={DEFAULT_OG_IMAGE}
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
    { name: `Page ${pageNumber}`, path: blogPagePath(pageNumber) }
  ]}
>
  <section class="blog-index">
    <div class="container blog-index__hero">
      <p class="blog-index__eyebrow">Safari stories</p>
      <h1>More Kenya safari notes.</h1>
      <p>Page {pageNumber} of {totalPages}.</p>
    </div>

    <div class="container blog-index__content">
      <div class="blog-grid" aria-label="Blog posts">
        {pagePosts.map((post) => <BlogCard post={post} />)}
      </div>

      <nav class="blog-pagination" aria-label="Blog pagination">
        {previousPage >= 1 && <a href={blogPagePath(previousPage)}>Previous</a>}
        {
          Array.from({ length: totalPages }, (_, index) => index + 1).map((page) =>
            page === pageNumber ? (
              <span aria-current="page">{page}</span>
            ) : (
              <a href={blogPagePath(page)}>{page}</a>
            )
          )
        }
        {nextPage <= totalPages && <a href={blogPagePath(nextPage)}>Next</a>}
      </nav>

      <p class="blog-index__note">
        Showing {(pageNumber - 1) * POSTS_PER_PAGE + 1}-{Math.min(pageNumber * POSTS_PER_PAGE, totalPosts)} of {totalPosts} stories.
      </p>
    </div>
  </section>
</BlogLayout>

<style>
  .blog-index {
    padding-block: var(--space-16);
  }

  .blog-index__hero {
    max-width: 52rem;
    display: grid;
    gap: var(--space-4);
    margin-inline: auto;
    text-align: center;
  }

  .blog-index__eyebrow {
    margin: 0;
    color: var(--color-clay);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
  }

  .blog-index__hero h1 {
    margin: 0;
    color: var(--color-midnight);
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-semibold);
    line-height: var(--line-heading);
  }

  .blog-index__hero p,
  .blog-index__note {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: var(--text-md);
  }

  .blog-index__content {
    display: grid;
    gap: var(--space-8);
    padding-block-start: var(--space-12);
  }

  .blog-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 44rem) {
    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 68rem) {
    .blog-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .blog-pagination {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    justify-content: center;
  }

  .blog-pagination a,
  .blog-pagination span {
    min-width: 2.75rem;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    padding-inline: var(--space-3);
    color: var(--color-midnight);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }

  .blog-pagination span {
    border-color: var(--color-midnight);
    background: var(--color-midnight);
    color: var(--color-ivory);
  }

  .blog-pagination a:hover {
    border-color: var(--color-gold);
    color: var(--color-clay);
  }

  .blog-index__note {
    text-align: center;
  }
</style>
